<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Templates des 8 styles du widget de sessions (refonte visuelle), PARTAGÉS entre la fenêtre réelle
         (SessionsWindow) et la galerie de prévisualisation. Loi commune : mouvement réservé à l'attente ;
         « à toi » (Attention) respire, « tour fini » (Turn) fixe ; déduit (Ghost) = fantôme. -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- Pouls lent RÉSERVÉ à « à toi » (WaitingAttention). Appliqué à l'élément coloré de chaque style. -->
    <Style x:Key="PulseAttention" TargetType="FrameworkElement">
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsAttention}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard Name="pulseSb">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.4" Duration="0:0:1.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="pulseSb"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Bulle de survol (style implicite) : petite étiquette sombre arrondie avec le nom de la session.
         Couleurs fixes (les popups résolvent mal les DynamicResource du thème). S'applique à tous les
         ToolTip="{Binding Project}" des icônes de session. -->
    <Style TargetType="ToolTip">
        <Setter Property="Foreground" Value="#F4F2EC"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="#F2201C2A" CornerRadius="7" Padding="9,5">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================ 1 · PASTILLES (historique) ============================ -->
    <DataTemplate x:Key="TplPastilles">
        <ItemsControl ItemsSource="{Binding Items}" Background="#01000000" Padding="2">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="9" Padding="10,7" Margin="0,3" MinWidth="180" Background="{DynamicResource SessPanel}"
                            ToolTip="{Binding Project}" ToolTipService.InitialShowDelay="300">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.35" Color="Black"/>
                        </Border.Effect>
                        <Border.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Archiver (retirer de l'overlay)" Command="{Binding ArchiveCommand}"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                            <Ellipse Width="10" Height="10" Fill="{Binding StateBrush}"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Style="{StaticResource PulseAttention}"/>
                            <StackPanel Margin="20,0,0,0">
                                <TextBlock Text="{Binding Project}" Foreground="{DynamicResource SessInk}" FontSize="12.5"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                    <TextBlock Text="{Binding StateText}" Foreground="{Binding StateBrush}" FontSize="10.5" FontWeight="SemiBold"/>
                                    <TextBlock Text="  ·  " Foreground="{DynamicResource SessMuted}" FontSize="10.5"/>
                                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource SessMuted}" FontSize="10.5"/>
                                    <TextBlock Text="  ·  " Foreground="{DynamicResource SessMuted}" FontSize="10.5">
                                        <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers>
                                            <DataTrigger Binding="{Binding KindLabel}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                        </Style.Triggers></Style></TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding KindLabel}" Foreground="{DynamicResource SessMuted}" FontSize="10.5" FontWeight="SemiBold">
                                        <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers>
                                            <DataTrigger Binding="{Binding KindLabel}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                        </Style.Triggers></Style></TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DataTemplate>

    <!-- ============================ 2 · MARGE (liste à liseré) ============================ -->
    <DataTemplate x:Key="TplMarge">
        <ItemsControl ItemsSource="{Binding Items}" Background="#01000000" Padding="2" MinWidth="190">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource SessPanel}" CornerRadius="7" Margin="0,2" Padding="0,0,10,0"
                            ToolTip="{Binding Project}" ToolTipService.InitialShowDelay="300">
                        <Border.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Archiver (retirer de l'overlay)" Command="{Binding ArchiveCommand}"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Width="3.5" RadiusX="2" RadiusY="2" Margin="0,5"
                                       Fill="{Binding StateBrush}" Style="{StaticResource PulseAttention}"/>
                            <StackPanel Grid.Column="1" Margin="9,5,0,5">
                                <TextBlock Text="{Binding Project}" Foreground="{DynamicResource SessInk}" FontSize="12.5"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding StateText}" Foreground="{Binding StateBrush}" FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock Text="  ·  " Foreground="{DynamicResource SessMuted}" FontSize="10"/>
                                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource SessMuted}" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DataTemplate>

    <!-- ============================ 3 · JETONS QUI LÈVENT LA MAIN ============================ -->
    <DataTemplate x:Key="TplJetons">
        <Border Background="{DynamicResource SessPanel}" CornerRadius="12" Padding="8,6">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="{Binding DataContext.RowOrientation, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="52" Height="52" Margin="3,0" Background="#01000000"
                              ToolTip="{Binding Project}" ToolTipService.InitialShowDelay="300">
                            <Grid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Archiver" Command="{Binding ArchiveCommand}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                <Grid Width="24" Height="24" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                                    <Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="-13"/></Setter.Value></Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsWorking}" Value="True"><Setter Property="Opacity" Value="0.55"/></DataTrigger>
                                                <DataTrigger Binding="{Binding IsGhost}" Value="True"><Setter Property="Opacity" Value="0.4"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Ellipse Width="24" Height="24" Fill="{Binding StateBrush}" Opacity="0.22" Style="{StaticResource PulseAttention}"/>
                                    <Ellipse Width="14" Height="14" Fill="{Binding StateBrush}"/>
                                </Grid>
                                <TextBlock Text="{Binding Project}" FontSize="8.5" Foreground="{DynamicResource SessMuted}" HorizontalAlignment="Center"
                                           MaxWidth="50" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </DataTemplate>

    <!-- ============================ 4 · SONAR (ping) ============================ -->
    <DataTemplate x:Key="TplSonar">
        <Border Background="{DynamicResource SessPanel}" CornerRadius="12" Padding="8,6">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="{Binding DataContext.RowOrientation, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="34" Height="34" Margin="3" Background="#01000000"
                              ToolTip="{Binding Project}" ToolTipService.InitialShowDelay="300">
                            <Grid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Archiver" Command="{Binding ArchiveCommand}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Ellipse Width="16" Height="16" Stroke="{Binding StateBrush}" StrokeThickness="1.6" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><ScaleTransform x:Name="pingScale"/></Ellipse.RenderTransform>
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="ping">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.5" To="2.3" Duration="0:0:2.2"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.5" To="2.3" Duration="0:0:2.2"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.85" To="0" Duration="0:0:2.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions><StopStoryboard BeginStoryboardName="ping"/></DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <Ellipse Width="9" Height="9" Fill="{Binding StateBrush}">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGhost}" Value="True"><Setter Property="Opacity" Value="0.4"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </DataTemplate>

    <!-- ============================ 5 · FAÇADE NOCTURNE ============================ -->
    <DataTemplate x:Key="TplFacade">
        <Border Background="#E6100E17" CornerRadius="12" Padding="8" BorderBrush="#2A2733" BorderThickness="1">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel MaxWidth="118"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="26" Height="20" Margin="3" CornerRadius="3" Background="{Binding StateBrush}" ToolTip="{Binding Project}">
                            <Border.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Archiver" Command="{Binding ArchiveCommand}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource PulseAttention}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWorking}" Value="True"><Setter Property="Opacity" Value="0.45"/></DataTrigger>
                                        <DataTrigger Binding="{Binding IsGhost}" Value="True"><Setter Property="Opacity" Value="0.22"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </DataTemplate>

    <!-- ============================ 6 · ÉTAGÈRE QUI BASCULE ============================ -->
    <DataTemplate x:Key="TplEtagere">
        <Border Background="{DynamicResource SessPanel}" CornerRadius="12" Padding="10,8">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="40" Height="70" Margin="1" Background="#01000000"
                              ToolTip="{Binding Project}" ToolTipService.InitialShowDelay="300">
                            <Grid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Archiver" Command="{Binding ArchiveCommand}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Rectangle VerticalAlignment="Bottom" HorizontalAlignment="Center" Height="60" RadiusX="2" RadiusY="2"
                                       Fill="{Binding StateBrush}" RenderTransformOrigin="0.5,1">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Width" Value="9"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAttention}" Value="True">
                                                <Setter Property="Width" Value="26"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard Name="pb"><Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.5" Duration="0:0:1.2"/>
                                                    </Storyboard></BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions><StopStoryboard BeginStoryboardName="pb"/></DataTrigger.ExitActions>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTurn}" Value="True">
                                                <Setter Property="Width" Value="11"/>
                                                <Setter Property="RenderTransform"><Setter.Value><RotateTransform Angle="22"/></Setter.Value></Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsGhost}" Value="True"><Setter Property="Opacity" Value="0.35"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </DataTemplate>

    <!-- ============================ 7 · VOYANTS + COMPTEUR (annonciateur) ============================ -->
    <DataTemplate x:Key="TplAnnonciateur">
        <Border Background="{DynamicResource SessPanel}" CornerRadius="14" Padding="12,10" MinWidth="150">
            <StackPanel>
                <Border CornerRadius="16" Padding="14,5" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#2A2732"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasWaiting}" Value="True"><Setter Property="Background" Value="{DynamicResource SessAttention}"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding WaitingCount}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Style><Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource SessMuted}"/>
                                <Style.Triggers><DataTrigger Binding="{Binding HasWaiting}" Value="True"><Setter Property="Foreground" Value="#161019"/></DataTrigger></Style.Triggers>
                            </Style></TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="  en attente" FontSize="11" VerticalAlignment="Center" Margin="2,0,0,0">
                            <TextBlock.Style><Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#8C8A98"/>
                                <Style.Triggers><DataTrigger Binding="{Binding HasWaiting}" Value="True"><Setter Property="Foreground" Value="#3A2A12"/></DataTrigger></Style.Triggers>
                            </Style></TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="6" Margin="0,2" Padding="8,4" Background="{Binding StateBrush}" ToolTip="{Binding Project}">
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Archiver" Command="{Binding ArchiveCommand}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource PulseAttention}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWorking}" Value="True"><Setter Property="Opacity" Value="0.5"/></DataTrigger>
                                            <DataTrigger Binding="{Binding IsGhost}" Value="True"><Setter Property="Opacity" Value="0.3"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Project}" Foreground="#161019" FontSize="11" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </DataTemplate>

    <!-- ============================ 8 · VEILLEURS (regards) ============================ -->
    <DataTemplate x:Key="TplVeilleurs">
        <Border Background="{DynamicResource SessPanel}" CornerRadius="12" Padding="10,8">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="{Binding DataContext.RowOrientation, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="34" Height="30" Margin="3" Background="#01000000"
                              ToolTip="{Binding Project}" ToolTipService.InitialShowDelay="300">
                            <Grid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="Archiver" Command="{Binding ArchiveCommand}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Grid Visibility="{Binding IsWaiting, Converter={StaticResource BoolToVis}}">
                                <Ellipse Width="28" Height="18" Fill="#EDE6D6"/>
                                <Ellipse Width="13" Height="13" Fill="{Binding StateBrush}" Style="{StaticResource PulseAttention}"/>
                                <Ellipse Width="5" Height="5" Fill="#201810">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTurn}" Value="True"><Setter Property="Margin" Value="0,-6,0,0"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </Grid>
                            <Path Stretch="None" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 3,15 Q 17,7 31,15">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Stroke" Value="#5A5768"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWaiting}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                            <DataTrigger Binding="{Binding IsGhost}" Value="True">
                                                <Setter Property="Opacity" Value="0.45"/>
                                                <Setter Property="StrokeDashArray" Value="2 2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </DataTemplate>
</ResourceDictionary>
