<Window x:Class="Chronos.Views.CadranGalleryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cadv="clr-namespace:Chronos.Views.Cadrans"
        Title="Chronos — galerie des cadrans (prototype)"
        Width="960" Height="680" WindowStartupLocation="CenterScreen"
        Background="#0D0C12" FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Lbl">
            <Setter Property="Foreground" Value="#A9A8B2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Tile">
            <Setter Property="Foreground" Value="#F4F2EC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="TileSub">
            <Setter Property="Foreground" Value="#75727F"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Cadrans — 4 pistes" Foreground="#F4F2EC" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Text="données d'échantillon pilotables" Style="{StaticResource TileSub}" Margin="12,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="Thème" Style="{StaticResource Lbl}" Margin="28,0,8,0"/>
            <ComboBox Width="140" VerticalAlignment="Center"
                      ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                      DisplayMemberPath="Name"/>
            <CheckBox Content="Afficher le temps (sinon %)" IsChecked="{Binding ShowCountdown, Mode=TwoWay}"
                      Foreground="#A9A8B2" VerticalAlignment="Center" Margin="24,0,0,0"/>
        </StackPanel>

        <!-- Curseurs de scénario -->
        <Border Grid.Row="1" Background="#15131D" CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 5 h -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Fenêtre 5 h" Foreground="#E9A23C" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="96"/><ColumnDefinition Width="*"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Temps restant" Style="{StaticResource Lbl}"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding FiveTimePct, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding FiveTimePct, StringFormat={}{0:0} %}" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="96"/><ColumnDefinition Width="*"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Quota consommé" Style="{StaticResource Lbl}"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding FiveQuotaPct, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding FiveQuotaPct, StringFormat={}{0:0} %}" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                    </Grid>
                    <CheckBox Content="Estimé (repli JSONL → grain)" IsChecked="{Binding FiveEstimated, Mode=TwoWay}"
                              Foreground="#A9A8B2" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- 7 j -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Fenêtre hebdomadaire" Foreground="#E9A23C" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="96"/><ColumnDefinition Width="*"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Temps restant" Style="{StaticResource Lbl}"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding SevenTimePct, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding SevenTimePct, StringFormat={}{0:0} %}" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="96"/><ColumnDefinition Width="*"/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Quota consommé" Style="{StaticResource Lbl}"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding SevenQuotaPct, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding SevenQuotaPct, StringFormat={}{0:0} %}" Style="{StaticResource Lbl}" HorizontalAlignment="Right"/>
                    </Grid>
                    <CheckBox Content="Estimé (repli JSONL → grain)" IsChecked="{Binding SevenEstimated, Mode=TwoWay}"
                              Foreground="#A9A8B2" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Les 4 cadrans -->
        <UniformGrid Grid.Row="2" Columns="2" Rows="2">
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="16,12" VerticalAlignment="Top">
                        <TextBlock Text="Anneau de braises" Style="{StaticResource Tile}"/>
                        <TextBlock Text="nombre de braises = temps · couleur = quota" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <cadv:CadranBraisesView VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="16,12" VerticalAlignment="Top">
                        <TextBlock Text="Le fusible" Style="{StaticResource Tile}"/>
                        <TextBlock Text="position du front = temps · épaisseur+couleur = quota" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <cadv:CadranFusibleView VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="16,12" VerticalAlignment="Top">
                        <TextBlock Text="La marée" Style="{StaticResource Tile}"/>
                        <TextBlock Text="hauteur de lumière = temps · luminance = quota" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <cadv:CadranMareeView VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="16,12" VerticalAlignment="Top">
                        <TextBlock Text="L'afficheur à volets" Style="{StaticResource Tile}"/>
                        <TextBlock Text="chiffre exact = temps · plaque = quota" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <cadv:CadranVoletsView VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
        </UniformGrid>
    </Grid>
</Window>
