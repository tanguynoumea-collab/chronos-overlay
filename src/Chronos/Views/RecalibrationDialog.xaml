<Window x:Class="Chronos.Views.RecalibrationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recalibrer le reset hebdo"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="#16151B" FontFamily="Segoe UI">
    <!-- Dialogue MINIMAL et sombre, cohérent avec l'overlay (tokens de DesignTokens.xaml).
         Un DatePicker (pointer une date de reset hebdo connue) + « Caler sur maintenant »,
         plus Valider/Annuler. Aucune logique en code-behind hors traduction CloseRequested → DialogResult. -->
    <Window.Resources>
        <ResourceDictionary Source="pack://application:,,,/Chronos;component/Resources/DesignTokens.xaml"/>
    </Window.Resources>

    <StackPanel Margin="18" MinWidth="260">
        <TextBlock Text="Le reset hebdomadaire dérive (~72 h). Pointez la date d'un reset connu, ou calez sur maintenant."
                   TextWrapping="Wrap" MaxWidth="260"
                   FontSize="12" Foreground="{StaticResource TexteSecondaireClair}"/>

        <TextBlock Text="Date d'ancrage" Margin="0,14,0,4"
                   FontSize="11" Foreground="{StaticResource TexteSecondaire}"/>
        <DatePicker x:Name="SelecteurDate" SelectedDate="{Binding SelectedDate, Mode=TwoWay}"/>

        <Button Content="Caler sur maintenant" Margin="0,10,0,0" Padding="8,4"
                HorizontalAlignment="Left" Command="{Binding NowCommand}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Annuler" Padding="12,4" MinWidth="80"
                    Command="{Binding CancelCommand}" IsCancel="True"/>
            <Button Content="Valider" Padding="12,4" MinWidth="80" Margin="8,0,0,0"
                    Command="{Binding ValidateCommand}" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
