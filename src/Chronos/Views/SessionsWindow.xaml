<Window x:Class="Chronos.Views.SessionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        ShowInTaskbar="False" ShowActivated="False" Topmost="True"
        WindowStartupLocation="Manual" FontFamily="Segoe UI">
    <!-- Panneau CHROMELESS. Le STYLE (refonte visuelle) est choisi dans les réglages ; un ContentControl
         sélectionne le template correspondant via IsStyleX. Templates partagés (Resources/SessionStyles.xaml)
         avec la galerie de prévisualisation. Loi : mouvement réservé à l'attente ; « à toi » respire,
         « tour fini » fixe ; déduit = fantôme. -->
    <Window.Resources>
        <ResourceDictionary Source="pack://application:,,,/Chronos;component/Resources/SessionStyles.xaml"/>
    </Window.Resources>

    <!-- Glisser n'importe où = déplacer. Le ContentControl choisit le template selon le style courant. -->
    <Grid Background="#01000000" MouseLeftButtonDown="Drag">
        <ContentControl Content="{Binding}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="ContentTemplate" Value="{StaticResource TplPastilles}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStyleMarge}" Value="True"><Setter Property="ContentTemplate" Value="{StaticResource TplMarge}"/></DataTrigger>
                        <DataTrigger Binding="{Binding IsStyleJetons}" Value="True"><Setter Property="ContentTemplate" Value="{StaticResource TplJetons}"/></DataTrigger>
                        <DataTrigger Binding="{Binding IsStyleSonar}" Value="True"><Setter Property="ContentTemplate" Value="{StaticResource TplSonar}"/></DataTrigger>
                        <DataTrigger Binding="{Binding IsStyleFacade}" Value="True"><Setter Property="ContentTemplate" Value="{StaticResource TplFacade}"/></DataTrigger>
                        <DataTrigger Binding="{Binding IsStyleEtagere}" Value="True"><Setter Property="ContentTemplate" Value="{StaticResource TplEtagere}"/></DataTrigger>
                        <DataTrigger Binding="{Binding IsStyleAnnonciateur}" Value="True"><Setter Property="ContentTemplate" Value="{StaticResource TplAnnonciateur}"/></DataTrigger>
                        <DataTrigger Binding="{Binding IsStyleVeilleurs}" Value="True"><Setter Property="ContentTemplate" Value="{StaticResource TplVeilleurs}"/></DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Grid>
</Window>
