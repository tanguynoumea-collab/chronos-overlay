<Window x:Class="Chronos.Views.SessionsGalleryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chronos — galerie des sessions (prototype)"
        Width="1000" Height="640" WindowStartupLocation="CenterScreen"
        Background="#0D0C12" FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Chronos;component/Resources/SessionStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBlock" x:Key="Tile">
                <Setter Property="Foreground" Value="#F4F2EC"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
            <Style TargetType="TextBlock" x:Key="TileSub">
                <Setter Property="Foreground" Value="#75727F"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Sessions — 8 styles" Foreground="#F4F2EC" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Text="données d'échantillon · 2 en attente, 2 en cours, 1 fantôme" Style="{StaticResource TileSub}"
                       Margin="12,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="4" Rows="2">
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="14,10" VerticalAlignment="Top">
                        <TextBlock Text="Pastilles" Style="{StaticResource Tile}"/>
                        <TextBlock Text="liste historique" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource TplPastilles}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="14,10" VerticalAlignment="Top">
                        <TextBlock Text="Marge" Style="{StaticResource Tile}"/>
                        <TextBlock Text="liste à liseré, tri en tête" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource TplMarge}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="14,10" VerticalAlignment="Top">
                        <TextBlock Text="Jetons" Style="{StaticResource Tile}"/>
                        <TextBlock Text="l'attente lève la main" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource TplJetons}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="14,10" VerticalAlignment="Top">
                        <TextBlock Text="Sonar" Style="{StaticResource Tile}"/>
                        <TextBlock Text="seul l'attente pingue" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource TplSonar}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="14,10" VerticalAlignment="Top">
                        <TextBlock Text="Façade" Style="{StaticResource Tile}"/>
                        <TextBlock Text="immeuble la nuit" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource TplFacade}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="14,10" VerticalAlignment="Top">
                        <TextBlock Text="Étagère" Style="{StaticResource Tile}"/>
                        <TextBlock Text="l'attente se tourne vers toi" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource TplEtagere}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="14,10" VerticalAlignment="Top">
                        <TextBlock Text="Voyants" Style="{StaticResource Tile}"/>
                        <TextBlock Text="compteur maître + tuiles" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource TplAnnonciateur}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
            <Border Margin="6" CornerRadius="14" Background="#0A0910" BorderBrush="#2A2833" BorderThickness="1">
                <Grid>
                    <StackPanel Margin="14,10" VerticalAlignment="Top">
                        <TextBlock Text="Veilleurs" Style="{StaticResource Tile}"/>
                        <TextBlock Text="le regard qui te fixe" Style="{StaticResource TileSub}"/>
                    </StackPanel>
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource TplVeilleurs}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
        </UniformGrid>
    </Grid>
</Window>
