<Window x:Class="Chronos.Views.BudgetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibrer les plafonds"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="#16151B" FontFamily="Segoe UI">
    <!-- Dialogue MINIMAL et sombre, cohérent avec l'overlay (tokens de DesignTokens.xaml).
         Deux champs numériques (plafond 5 h, plafond hebdo) + Valider/Annuler. Aucune logique en
         code-behind hors traduction CloseRequested → DialogResult (elle vit dans le VM). -->
    <Window.Resources>
        <ResourceDictionary Source="pack://application:,,,/Chronos;component/Resources/DesignTokens.xaml"/>
    </Window.Resources>

    <StackPanel Margin="18" MinWidth="260">
        <TextBlock Text="Renseignez les plafonds de tokens pour colorer les arcs. Laissez vide pour ne pas colorer l'arc."
                   TextWrapping="Wrap" MaxWidth="260"
                   FontSize="12" Foreground="{StaticResource TexteSecondaireClair}"/>

        <TextBlock Text="Plafond 5 h (tokens)" Margin="0,14,0,4"
                   FontSize="11" Foreground="{StaticResource TexteSecondaire}"/>
        <TextBox x:Name="ChampCinqHeures"
                 Text="{Binding FiveHourText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Text="Plafond hebdo (tokens)" Margin="0,12,0,4"
                   FontSize="11" Foreground="{StaticResource TexteSecondaire}"/>
        <TextBox x:Name="ChampHebdo"
                 Text="{Binding WeeklyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Annuler" Padding="12,4" MinWidth="80"
                    Command="{Binding CancelCommand}" IsCancel="True"/>
            <Button Content="Valider" Padding="12,4" MinWidth="80" Margin="8,0,0,0"
                    Command="{Binding ValidateCommand}" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
