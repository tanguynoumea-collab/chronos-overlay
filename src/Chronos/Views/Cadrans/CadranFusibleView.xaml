<UserControl x:Class="Chronos.Views.Cadrans.CadranFusibleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cad="clr-namespace:Chronos.Controls"
             Background="Transparent">
    <!-- Piste 2 — Fusible. Deux mèches : 5 h (haut, épaisse) + 7 j (bas). Position du front = temps ;
         épaisseur + couleur = quota ; part écoulée = sillon creux ; estimé = cordon muet pointillé.
         Valeur par ligne : bascule % (défaut) ↔ temps (ShowPercent/ShowCountdown, clic au centre). -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <StackPanel Width="210" VerticalAlignment="Center" HorizontalAlignment="Center">
        <!-- 5 H -->
        <Grid Margin="2,0,0,3">
            <TextBlock Text="5 H" Foreground="#A9A8B2" FontSize="11" FontWeight="SemiBold"/>
            <Grid HorizontalAlignment="Right">
                <TextBlock Text="{Binding FiveHour.UtilizationText}" Foreground="#F4F2EC" FontSize="12" FontWeight="SemiBold"
                           Visibility="{Binding ShowPercent, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding FiveHour.CountdownText}" Foreground="#F4F2EC" FontSize="12" FontWeight="SemiBold"
                           Visibility="{Binding ShowCountdown, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Grid>
        <cad:FuseBar Height="26" CordThickness="11"
                     Fraction="{Binding FiveHour.FractionRemaining}"
                     QuotaBrush="{Binding FiveHour.ValueBrush}"
                     Estimated="{Binding FiveHour.IsEstimated}"
                     HasData="{Binding FiveHour.HasTime}"/>
        <!-- 7 J -->
        <Grid Margin="2,14,0,3">
            <TextBlock Text="7 J" Foreground="#A9A8B2" FontSize="11" FontWeight="SemiBold"/>
            <Grid HorizontalAlignment="Right">
                <TextBlock Text="{Binding SevenDay.UtilizationText}" Foreground="#F4F2EC" FontSize="12" FontWeight="SemiBold"
                           Visibility="{Binding ShowPercent, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding SevenDay.CountdownText}" Foreground="#F4F2EC" FontSize="12" FontWeight="SemiBold"
                           Visibility="{Binding ShowCountdown, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Grid>
        <cad:FuseBar Height="24" CordThickness="9"
                     Fraction="{Binding SevenDay.FractionRemaining}"
                     QuotaBrush="{Binding SevenDay.ValueBrush}"
                     Estimated="{Binding SevenDay.IsEstimated}"
                     HasData="{Binding SevenDay.HasTime}"/>
    </StackPanel>
</UserControl>
