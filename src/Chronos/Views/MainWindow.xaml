<Window x:Class="Chronos.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Chronos.Controls"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize" SizeToContent="Manual"
        Width="170" Height="170" WindowStartupLocation="Manual">
    <!-- Cadran complet (Pattern 6 : empilement du fond vers le premier plan).
         Aucune Storyboard/blur/shadow : AllowsTransparency force le rendu logiciel.
         Aucun code-behind : uniquement des bindings + converters. Centre = 85,85 (Grid 170×170).
         Refonte v1.3 : 3 anneaux réordonnés (hebdo interne → 5 h milieu → 24 h externe),
         remplissage inversé (FractionElapsed), anneau timeline 24 h + % au centre. -->
    <Window.Resources>
        <!-- Tokens de design + converters, au niveau fenêtre : la vue est autonome (les StaticResource
             résolvent sans dépendre d'une Application démarrée). Source unique : Resources/DesignTokens.xaml. -->
        <ResourceDictionary Source="pack://application:,,,/Chronos;component/Resources/DesignTokens.xaml"/>
    </Window.Resources>
    <Grid>
        <!-- Menu contextuel = SEUL point d'accès/sortie (FEN-06). Attaché à la Grid racine dont le
             DataContext est le VM → les 4 MenuItem héritent du DataContext (Pattern 4 / Pitfall 5).
             Clic gauche = drag (code-behind), clic droit = ce menu → aucun conflit. -->
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Arrière-plan" IsCheckable="True"
                          IsChecked="{Binding IsBackground}"
                          Command="{Binding ToggleBackgroundCommand}"/>
                <MenuItem Header="Recalibrer le reset hebdo…"
                          Command="{Binding RecalibrateCommand}"/>
                <MenuItem Header="Calibrer les plafonds…"
                          Command="{Binding CalibrateBudgetsCommand}"/>
                <MenuItem Header="Lancer au démarrage" IsCheckable="True"
                          IsChecked="{Binding IsAutostart}"
                          Command="{Binding ToggleAutostartCommand}"/>
                <MenuItem Header="Usage exact (OAuth)" IsCheckable="True"
                          IsChecked="{Binding IsOAuthUsageEnabled}"
                          Command="{Binding ToggleOAuthUsageCommand}"/>
                <Separator/>
                <MenuItem Header="Quitter" Command="{Binding QuitCommand}"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <!-- Fond + rim (cadran 156 px pour laisser respirer l'anneau 24 h externe à 170 px) -->
        <Ellipse Width="156" Height="156"
                 Fill="{StaticResource FondCadran}"
                 Stroke="{StaticResource Rim}" StrokeThickness="2"/>

        <!-- Pistes (arcs pleins de fond), ordre centre → extérieur (VIS-02) :
             hebdo (interne, R44) → 5 h (milieu, R58) → 24 h (externe, R72). -->
        <ctrl:RingArc Fraction="1" Radius="44"
                      Stroke="{StaticResource PisteHebdo}" StrokeThickness="9"/>
        <ctrl:RingArc Fraction="1" Radius="58"
                      Stroke="{StaticResource Piste5h}" StrokeThickness="9"/>
        <ctrl:RingArc Fraction="1" Radius="72"
                      Stroke="{StaticResource Piste24h}" StrokeThickness="9"/>

        <!-- Arc valeur hebdo (interne, R44) : remplissage INVERSÉ (VIS-01) → FractionElapsed,
             se remplit à mesure qu'on approche du reset. Couleur = utilization hebdo. -->
        <ctrl:RingArc x:Name="ArcHebdo" Radius="44" StrokeThickness="9"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Fraction="{Binding SevenDay.FractionElapsed}"
                      Stroke="{Binding SevenDay.Utilization, Converter={StaticResource UtilBrush}}"/>

        <!-- Arc valeur 5 h (milieu, R58) : remplissage inversé (VIS-01) → FractionElapsed. -->
        <ctrl:RingArc x:Name="ArcCinqHeures" Radius="58" StrokeThickness="9"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Fraction="{Binding FiveHour.FractionElapsed}"
                      Stroke="{Binding FiveHour.Utilization, Converter={StaticResource UtilBrush}}"/>

        <!-- Anneau timeline 24 h (externe, R72) : rempli selon la fraction du jour (JOUR-01),
             couleur = utilization 5 h (JOUR-03, même rampe que l'anneau 5 h). -->
        <ctrl:RingArc x:Name="ArcVingtQuatreHeures" Radius="72" StrokeThickness="9"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Fraction="{Binding DayFraction}"
                      Stroke="{Binding FiveHour.Utilization, Converter={StaticResource UtilBrush}}"/>

        <!-- Ticks des resets 5 h projetés sur l'axe 24 h (JOUR-02), bord externe de l'anneau 24 h. -->
        <ctrl:TickRing Radius="76" TickLength="6"
                       Angles="{Binding DayResetAngles}"
                       Stroke="{StaticResource TickMajeur}" StrokeThickness="2"/>

        <!-- Bloc central : signaux PAR FENÊTRE (fiabilité/épuisement diffèrent entre 5 h et hebdo) + mentions globales -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- Groupe 5 h -->
            <TextBlock x:Name="TexteCinqHeures" HorizontalAlignment="Center"
                       FontSize="26" FontWeight="SemiBold"
                       Text="{Binding FiveHour.CountdownText}"
                       Foreground="{StaticResource TextePrincipal}"/>
            <TextBlock x:Name="BadgeEstimeeCinqHeures" HorizontalAlignment="Center"
                       FontSize="10" Text="estimée"
                       Visibility="{Binding FiveHour.IsEstimated, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource TexteSecondaire}"/>
            <TextBlock x:Name="TexteEpuiseCinqHeures" HorizontalAlignment="Center"
                       FontSize="10" Text="quota épuisé"
                       Visibility="{Binding FiveHour.Exhausted, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource TexteSecondaire}"/>
            <!-- NET-02 : tokens estimés (matière première), texte discret, visible seulement si estimée -->
            <TextBlock x:Name="TokensCinqHeures" HorizontalAlignment="Center"
                       FontSize="9"
                       Text="{Binding FiveHour.TokensText}"
                       Visibility="{Binding FiveHour.HasTokens, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource TexteSecondaire}"/>

            <!-- Groupe hebdo (countdown en nuance secondaire claire #C7C6D0) -->
            <TextBlock x:Name="TexteHebdo" HorizontalAlignment="Center" Margin="0,4,0,0"
                       FontSize="15"
                       Text="{Binding SevenDay.CountdownText}"
                       Foreground="{StaticResource TexteSecondaireClair}"/>
            <TextBlock x:Name="BadgeEstimeeHebdo" HorizontalAlignment="Center"
                       FontSize="10" Text="estimée"
                       Visibility="{Binding SevenDay.IsEstimated, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource TexteSecondaire}"/>
            <TextBlock x:Name="TexteEpuiseHebdo" HorizontalAlignment="Center"
                       FontSize="10" Text="quota épuisé"
                       Visibility="{Binding SevenDay.Exhausted, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource TexteSecondaire}"/>
            <!-- NET-02 : tokens estimés hebdo, même traitement discret -->
            <TextBlock x:Name="TokensHebdo" HorizontalAlignment="Center"
                       FontSize="9"
                       Text="{Binding SevenDay.TokensText}"
                       Visibility="{Binding SevenDay.HasTokens, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource TexteSecondaire}"/>

            <!-- Mentions globales : staleness (texte secondaire) puis indisponible -->
            <TextBlock x:Name="TexteStale" HorizontalAlignment="Center" Margin="0,4,0,0"
                       FontSize="10" Text="données périmées"
                       Visibility="{Binding IsStale, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource TexteSecondaire}"/>
            <TextBlock x:Name="TexteIndisponible" HorizontalAlignment="Center"
                       FontSize="11" Text="données indisponibles"
                       Visibility="{Binding DataUnavailable, Converter={StaticResource BoolToVis}}"
                       Foreground="{StaticResource TexteSecondaire}"/>
        </StackPanel>
    </Grid>
</Window>
